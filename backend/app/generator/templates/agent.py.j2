)
{% elif agent.agent_type.value == "parallel" %}
{{ agent.name | to_var_name }} = ParallelAgent(
    name="{{ agent.name }}",
    sub_agents=[{% for sub in agent.sub_agents %}{{ sub.name | to_var_name }}{% if not loop.last %}, {% endif %}{% endfor %}],
)
{% elif agent.agent_type.value == "loop" %}
{{ agent.name | to_var_name }} = LoopAgent(
    name="{{ agent.name }}",
    sub_agents=[{% for sub in agent.sub_agents %}{{ sub.name | to_var_name }}{% if not loop.last %}, {% endif %}{% endfor %}],
)
{% endif %}
{% endfor %}

root_agent = {{ root_agent.name | to_var_name }}


